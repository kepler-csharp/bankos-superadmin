@model TenantModel
@{
    ViewBag.Title = Model.Name;
    var s = Model.Stats;
    string Fee() => Model.TransferFeeType == "percentage" ? $"{Model.TransferFeeValue}%" : $"{Model.TransferFeeValue:N0} (monto fijo)";
}

@section Head {
<style>
    .dt { display: grid; grid-template-columns: 1fr 360px; gap: 24px; align-items: start; }
    .sec-head { display: flex; align-items: center; gap: 11px; padding: 16px 22px; border-bottom: 1px solid var(--s-100); }
    .sec-head .ic { width: 34px; height: 34px; border-radius: 10px; display: grid; place-items: center; color: #fff; font-size: 14px; }
    .sec-head .t { font-family: var(--display); font-weight: 700; font-size: 15px; color: var(--ink); }
    .mini-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .mini { border: 1px solid var(--s-200); border-radius: 12px; padding: 16px; position: relative; overflow: hidden; }
    .mini::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; }
    .mini.b::before { background: var(--blue); } .mini.p::before { background: var(--purple); }
    .mini.g::before { background: var(--green); } .mini.c::before { background: var(--cyan); }
    .mini .v { font-family: var(--display); font-weight: 800; font-size: 26px; color: var(--ink); line-height: 1; }
    .mini .l { font-size: 12px; color: var(--s-500); margin-top: 6px; }
    .mini .ic { position: absolute; right: 14px; top: 14px; color: var(--s-300); font-size: 16px; }
    @@media (max-width: 920px) { .dt { grid-template-columns: 1fr; } }
</style>
}

<main class="main">
    <div class="page-header">
        <div>
            <div class="eyebrow"><a href="@Url.Action("Index")" style="color:var(--purple);text-decoration:none;">Bancos</a> · Detalle</div>
            <h1 class="page-title">
                <i class="fa-solid fa-building-columns" style="color:var(--purple);"></i> @Model.Name
                @if (Model.IsActive)
                {
                    <span class="badge badge-active" style="font-size:11px;"><i class="fa-solid fa-circle"></i> Activo</span>
                }
                else
                {
                    <span class="badge badge-inactive" style="font-size:11px;"><i class="fa-solid fa-circle"></i> Inactivo</span>
                }
            </h1>
            <p class="page-subtitle mono">tenant_@Model.Id</p>
        </div>
        <div style="display:flex;gap:9px;flex-wrap:wrap;">
            <a class="btn btn-brand" href="@Url.Action("Certificate", new { id = Model.Id })"><i class="fa-solid fa-file-arrow-down"></i> Certificado PDF</a>
            <a class="btn btn-secondary" href="@Url.Action("Edit", new { id = Model.Id })"><i class="fa-solid fa-pen"></i> Editar</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i><span>@TempData["Success"]</span></div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning"><i class="fa-solid fa-triangle-exclamation"></i><span>@TempData["Warning"]</span></div>
    }

    <div class="dt">
        <div>
            <!-- Live stats -->
            <div class="card" style="margin-bottom:20px;">
                <div class="sec-head">
                    <span class="ic" style="background:var(--rail);"><i class="fa-solid fa-chart-line"></i></span>
                    <div><div class="t">Métricas en vivo</div></div>
                    @if (s != null && s.Reachable)
                    {
                        <span class="badge badge-active" style="margin-left:auto;"><i class="fa-solid fa-circle"></i> Base de datos conectada</span>
                    }
                    else
                    {
                        <span class="badge badge-inactive" style="margin-left:auto;"><i class="fa-solid fa-plug-circle-xmark"></i> Sin conexión</span>
                    }
                </div>
                <div class="card-body">
                    @if (s != null && s.Reachable)
                    {
                        <div class="mini-grid">
                            <div class="mini b"><i class="fa-solid fa-users ic"></i><div class="v">@s.Users.ToString("N0")</div><div class="l">Usuarios</div></div>
                            <div class="mini p"><i class="fa-solid fa-wallet ic"></i><div class="v">@s.Accounts.ToString("N0")</div><div class="l">Cuentas</div></div>
                            <div class="mini g"><i class="fa-solid fa-right-left ic"></i><div class="v">@s.Transactions.ToString("N0")</div><div class="l">Transacciones</div></div>
                            <div class="mini c"><i class="fa-solid fa-table ic"></i><div class="v">@s.TableCount.ToString("N0")</div><div class="l">Tablas en la BD</div></div>
                        </div>
                        @if (s.Cards > 0)
                        {
                            <div class="mini b" style="margin-top:14px;"><i class="fa-solid fa-credit-card ic"></i><div class="v">@s.Cards.ToString("N0")</div><div class="l">Tarjetas</div></div>
                        }
                        <div style="margin-top:16px;text-align:right;">
                            <a class="btn btn-secondary btn-sm" href="@Url.Action("DbViewer", new { id = Model.Id })"><i class="fa-solid fa-database"></i> Explorar base de datos</a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info" style="margin:0;">
                            <i class="fa-solid fa-circle-info"></i>
                            <span>
                                No se pudo conectar con la base de datos <span class="mono">tenant_@Model.Id</span> para leer métricas en vivo.
                                @if (!string.IsNullOrEmpty(s?.Error)) { <br /><span class="mono" style="font-size:11px;">@s!.Error</span> }
                                <br />Verifica el acceso a PostgreSQL (puerto y firewall) en la configuración.
                            </span>
                        </div>
                    }
                </div>
            </div>

            <!-- Financial config -->
            <div class="card">
                <div class="sec-head">
                    <span class="ic" style="background:var(--blue);"><i class="fa-solid fa-coins"></i></span>
                    <div><div class="t">Configuración financiera</div></div>
                </div>
                <div class="card-body">
                    <table class="kv-table">
                        <tr><td>Moneda</td><td>@Model.Currency</td></tr>
                        <tr><td>Tipo de comisión</td><td>@(Model.TransferFeeType == "percentage" ? "Porcentaje" : "Monto fijo")</td></tr>
                        <tr><td>Comisión de transferencia</td><td>@Fee()</td></tr>
                        <tr><td>Límite por transacción</td><td>@Model.MaxTransactionAmount.ToString("N0") @Model.Currency</td></tr>
                    </table>

                    @if (Model.Config?.ExchangeRates != null && Model.Config.ExchangeRates.Count > 0)
                    {
                        <div class="section-label" style="margin:18px 0 10px;">Tasas de cambio</div>
                        <div class="table-wrap">
                            <table class="data">
                                <thead><tr><th>Divisa</th><th>Tasa</th></tr></thead>
                                <tbody>
                                    @foreach (var kv in Model.Config.ExchangeRates)
                                    {
                                        <tr><td class="mono">@kv.Key.ToUpper()</td><td>@kv.Value.ToString("N2")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <aside>
            <div class="card" style="margin-bottom:20px;">
                <div class="sec-head">
                    <span class="ic" style="background:var(--purple);"><i class="fa-solid fa-circle-info"></i></span>
                    <div><div class="t">Información</div></div>
                </div>
                <div class="card-body">
                    <table class="kv-table">
                        <tr><td>Identificador</td><td class="mono">@Model.Id</td></tr>
                        <tr><td>Base de datos</td><td class="mono" style="font-size:12px;">tenant_@Model.Id</td></tr>
                        <tr><td>Estado</td><td>@(Model.IsActive ? "Activo" : "Inactivo")</td></tr>
                        @if (!string.IsNullOrWhiteSpace(Model.AdminEmail))
                        {
                            <tr><td>Administrador</td><td style="font-size:12.5px;">@Model.AdminEmail</td></tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.WebhookUrl))
                        {
                            <tr><td>Webhook</td><td class="mono" style="font-size:11px;word-break:break-all;">@Model.WebhookUrl</td></tr>
                        }
                        @if (Model.CreatedAt.HasValue)
                        {
                            <tr><td>Creado</td><td>@Model.CreatedAt.Value.ToString("dd/MM/yyyy")</td></tr>
                        }
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <tr><td>Actualizado</td><td>@Model.UpdatedAt.Value.ToString("dd/MM/yyyy")</td></tr>
                        }
                    </table>
                </div>
            </div>

            <div class="card">
                <div class="sec-head">
                    <span class="ic" style="background:var(--green);"><i class="fa-solid fa-bolt"></i></span>
                    <div><div class="t">Acciones</div></div>
                </div>
                <div class="card-body" style="display:flex;flex-direction:column;gap:9px;">
                    <a class="btn btn-secondary btn-block" href="@Url.Action("DbViewer", new { id = Model.Id })"><i class="fa-solid fa-database"></i> Visor de base de datos</a>
                    <a class="btn btn-secondary btn-block" href="@Url.Action("Chat")"><i class="fa-solid fa-robot"></i> Preguntar al asistente</a>
                    <a class="btn btn-secondary btn-block" href="@Url.Action("Certificate", new { id = Model.Id })"><i class="fa-solid fa-file-arrow-down"></i> Descargar certificado</a>

                    <form method="post" action="@Url.Action("ToggleStatus")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="currentStatus" value="@Model.Status" />
                        <input type="hidden" name="adminEmail" value="@Model.AdminEmail" />
                        <input type="hidden" name="tenantName" value="@Model.Name" />
                        @if (Model.IsActive)
                        {
                            <button type="submit" class="btn btn-warning btn-block"
                                    onclick="return confirm('¿Desactivar el banco «@Model.Name»?');"><i class="fa-solid fa-pause"></i> Desactivar banco</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success btn-block"
                                    onclick="return confirm('¿Reactivar el banco «@Model.Name»?');"><i class="fa-solid fa-play"></i> Reactivar banco</button>
                        }
                    </form>

                    <form method="post" action="@Url.Action("Delete")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="adminEmail" value="@Model.AdminEmail" />
                        <input type="hidden" name="tenantName" value="@Model.Name" />
                        <button type="submit" class="btn btn-danger btn-block"
                                onclick="return confirm('¿Dar de baja el banco «@Model.Name»? Quedará desactivado y dejará de operar. Sus datos se conservan y puede reactivarse.');"><i class="fa-solid fa-ban"></i> Dar de baja</button>
                    </form>
                </div>
            </div>
        </aside>
    </div>
</main>
